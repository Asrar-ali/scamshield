GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# Optional MongoDB Atlas persistence — falls back to an in-memory store when unset.
MONGODB_URI=
MONGODB_DB=scamshield
PORT=3001
# Discord bot token from the Discord Developer Portal — ScamShield's monitoring
# bot. Falls back to "not connected" (GET /api/discord/status → enabled:false)
# when unset. The bot needs the Server Members + Message Content privileged intents
# enabled on the Developer Portal, and these intents granted when you invite it.
DISCORD_BOT_TOKEN=
# macOS-only iMessage alerts via Messages.app automation. Off by default;
# set to 1 to enable. Requires the host be signed into Messages with iMessage.
SCAMSHIELD_IMESSAGE_ENABLED=
# Optional GEMINI resilience: comma-separated extra keys (separate projects) and
# fallback models (separate daily quota buckets), tried when the primary is throttled.
GEMINI_API_KEYS=
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest
# Production hardening (unset = open, for the local/demo dashboard). When set, the
# operator token is required (header x-scamshield-token) on PUT /api/settings and
# POST /api/alert-test, and CORS is locked to the single allowed origin.
SCAMSHIELD_OPERATOR_TOKEN=
SCAMSHIELD_ALLOWED_ORIGIN=
