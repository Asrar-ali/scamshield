GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
ELEVENLABS_API_KEY=
# Voice IDs for POST /api/tts — defaults are ElevenLabs premade voices (Rachel/Antoni) if unset.
ELEVENLABS_VOICE_GRANDMA=
ELEVENLABS_VOICE_GUARDIAN=
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Optional MongoDB Atlas persistence — falls back to an in-memory store when unset.
MONGODB_URI=
MONGODB_DB=scamshield
PORT=3001
# Telegram bot token from @BotFather — Rose's real phone line. Falls back to
# "not connected" (GET /api/telegram/status → enabled:false) when unset.
TELEGRAM_BOT_TOKEN=
# macOS-only iMessage family alerts via Messages.app automation. Off by default;
# set to 1 to enable. Requires the host be signed into Messages with iMessage.
SCAMSHIELD_IMESSAGE_ENABLED=
